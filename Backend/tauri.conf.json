{
  "$schema": "../Frontend/node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Folio",
  "version": "0.1.1",
  "identifier": "com.folio.desktop",
  "build": {
    "frontendDist": "../Frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm --prefix Frontend run dev",
    "beforeBuildCommand": "npm --prefix Frontend run build"
  },
  "app": {
    "windows": [
      {
        "title": "Folio",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Hugolinokino/Folio/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJGNzE5RkRCQjFGNUIzNEMKUldSTXMvV3gyNTl4ditUYkxJejE4and6cS9DVVg0aTllNmh2RmN1azlON3VtSnNmRkJSVllhbGQK"
    }
  }
}
